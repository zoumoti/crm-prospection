# ============================================================
#  CRM Prospection — variables d'environnement
#  Copie ce fichier en .env.local et remplis les valeurs.
#  Sur Vercel : ajoute TOUTES ces variables dans
#  Project Settings → Environment Variables.
# ============================================================

# --- Frontend (Vite) — exposées au navigateur ---
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# --- Serverless (fonctions Vercel) — SECRÈTES, jamais exposées ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_WEBHOOK_SECRET=choisis-un-secret-aleatoire
PUBLIC_APP_URL=https://ton-app.vercel.app
