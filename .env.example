# ============================================================
#  CRM Prospection — variables d'environnement
#
#  1) Copie ce fichier en .env.local  (PowerShell : Copy-Item .env.example .env.local)
#  2) Remplis chaque valeur ci-dessous.
#  3) Mets EXACTEMENT les mêmes dans Vercel :
#     Project Settings → Environment Variables.
#
#  NB : ne mets PAS de commentaire à droite d'une valeur (garde-les sur
#  leurs propres lignes), sinon le script setup:telegram lit mal la valeur.
# ============================================================

# --- Frontend (Vite) — exposées au navigateur, ce n'est pas grave ---

# Supabase → Project Settings → API → "Project URL"
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase → Project Settings → API → "Project API keys" → anon public
VITE_SUPABASE_ANON_KEY=colle-la-cle-anon-ici

# --- Serverless (fonctions Vercel) — SECRÈTES, jamais exposées au navigateur ---

# La même URL que VITE_SUPABASE_URL
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase → Project Settings → API → "Project API keys" → service_role (SECRET)
SUPABASE_SERVICE_ROLE_KEY=colle-la-cle-service-role-ici

# Telegram → @BotFather → le token donné à la création du bot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Un secret que TU inventes (longue suite de lettres/chiffres au hasard)
TELEGRAM_WEBHOOK_SECRET=invente-un-secret-aleatoire-ici

# L'URL de ton app, connue APRÈS le 1er déploiement Vercel (ex. https://crm-xxx.vercel.app)
# Laisse vide tant que tu n'as pas déployé, puis renseigne-la et redeploie.
PUBLIC_APP_URL=https://ton-app.vercel.app
